{
  "statusLine": {
    "type": "command",
    "command": "{{STATUSLINE_CMD}}",
    "padding": 0
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "{{HOOK_CMD_SESSION_START}}" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "{{HOOK_CMD_USER_PROMPT_SUBMIT}}" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          { "type": "command", "command": "{{HOOK_CMD_PRE_TOOL_USE}}" }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "{{HOOK_CMD_SUBAGENT_STOP}}" }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "{{HOOK_CMD_STOP}}" }
        ]
      }
    ]
  }
}
