{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "{{HOOK_CMD_SESSION_START}}" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "{{HOOK_CMD_USER_PROMPT_SUBMIT}}" }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "{{HOOK_CMD_SUBAGENT_STOP}}" }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "{{HOOK_CMD_STOP}}" }
        ]
      }
    ]
  }
}
