{
  "_comment": "Scoped permission profile for headless harness runs (plan §8.2). Allows normal engineering inside the temp fixture; denies network and escape hatches. Used with --permission-mode acceptEdits, never --dangerously-skip-permissions.",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "Edit(.claude/memory/**)",
      "Write(.claude/memory/**)",
      "Edit(.claude/state/**)",
      "Write(.claude/state/**)",
      "Task",
      "TodoWrite",
      "Bash(python3:*)",
      "Bash(python:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(date:*)",
      "Bash(mkdir:*)"
    ],
    "deny": [
      "WebFetch",
      "WebSearch",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(git push:*)",
      "Bash(npm install:*)",
      "Bash(pip install:*)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)"
    ]
  }
}
